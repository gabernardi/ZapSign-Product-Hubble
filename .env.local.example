AUTH_SECRET=your-auth-secret-here
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ─────────────────────────────────────────────────────────────────────
# Changelog · fonte de dados (Bitbucket)
# ─────────────────────────────────────────────────────────────────────
# Usado em build time por scripts/generate-changelog.mjs para consultar
# a API do Bitbucket Cloud e puxar os PRs mergeados em produção dos
# repositórios reais da ZapSign.
#
# Escopos mínimos do app password:
#   Repositories: Read
#   Pull requests: Read
#
# Sem essas variáveis, o script preserva o changelog.generated.ts
# existente e o build não quebra (útil em CI sem secret).
BITBUCKET_USER=
BITBUCKET_APP_PASSWORD=
# BITBUCKET_WORKSPACE=truora
# BITBUCKET_REPOS=web,api
# BITBUCKET_BRANCH=main
# CHANGELOG_SINCE_DAYS=90

# ─────────────────────────────────────────────────────────────────────
# Changelog · IA (opcional, recomendado)
# ─────────────────────────────────────────────────────────────────────
# Para cada PR novo, uma única chamada decide se ele é user-facing e,
# quando for, reescreve título, descrição e impacto em linguagem humana.
# Sem a key, todo PR mergeado é publicado com o título original
# (sem classificação).
# Resultados ficam em lib/data/changelog-ai-cache.json (commitado).
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# CHANGELOG_AI=0          # força desabilitar mesmo com key presente
# CHANGELOG_AI_LIMIT=40   # limita quantos PRs novos são enriquecidos por run

# ─────────────────────────────────────────────────────────────────────
# Internacionalização (PT-BR / EN / ES) · IA + cache
# ─────────────────────────────────────────────────────────────────────
# A mesma OPENAI_API_KEY acima alimenta o seletor de idioma do Hubble e
# da tela de login. Ao trocar pra EN/ES, o motor varre o DOM e manda os
# textos novos pro endpoint /api/translate, que cacheia a resposta em
# Vercel Blob (translations-cache.json) — primeira tradução custa IA,
# próximas são free. Sem a key, o switcher devolve as strings originais.
# OPENAI_TRANSLATE_MODEL=gpt-4o-mini
